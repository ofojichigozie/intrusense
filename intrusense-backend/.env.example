# Server
PORT=5000

# MongoDB
MONGODB_URI=mongodb://localhost:27017/intrusense

# Auth
JWT_SECRET=change_this_to_a_long_random_secret

# Telegram (optional — leave blank to disable alerts during development)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Auth — expires in seconds (604800 = 7 days)
JWT_EXPIRES_IN=604800

# Device API key — must match x-api-key header sent by NodeMCU firmware
DEVICE_API_KEY=intrusense-device-secret

# CORS — set to frontend origin in production
CORS_ORIGIN=*
